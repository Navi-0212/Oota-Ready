[run]
source = app
omit =
    */tests/*
    */__pycache__/*
    */venv/*
    */env/*
    */migrations/*
    */config.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
    @staticmethod

[html]
directory = htmlcov
